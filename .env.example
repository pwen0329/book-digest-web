# Admin auth
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_API_SECRET=

# Persistent admin storage for Vercel/self-hosted production
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REGISTRATIONS_TABLE=registrations
SUPABASE_STORAGE_BUCKET=admin-assets

# Email Configuration
# Priority: RESEND > GMAIL (Resend is preferred, Gmail is fallback)

# Resend (preferred provider)
RESEND_API_KEY=
REGISTRATION_EMAIL_FROM=
REGISTRATION_EMAIL_REPLY_TO=

# Gmail (fallback provider - uses app password, not regular password)
# To generate app password: https://support.google.com/accounts/answer/185833
GMAIL_USER=
GMAIL_PASSWORD=

# Site URL
NEXT_PUBLIC_SITE_URL=

# Plausible Analytics (optional, privacy-friendly)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=

# Cloudflare Turnstile (bot protection)
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITEKEY=
TURNSTILE_SECRET_KEY=

# Sentry error monitoring (optional)
# Get DSN from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
