# Admin auth
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Persistent admin storage for Vercel/self-hosted production
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ADMIN_DOCUMENTS_TABLE=admin_documents
SUPABASE_REGISTRATIONS_TABLE=registrations
SUPABASE_STORAGE_BUCKET=admin-assets

# Public endpoints for external form processors (Formspree/Tally/Airtable webhook)
# If left empty, the app will simulate a success without network requests.
NEXT_PUBLIC_FORMS_ENDPOINT_TW=
NEXT_PUBLIC_FORMS_ENDPOINT_NL=

# Server-side Tally proxy (optional). If provided, /api/submit will forward payloads to these endpoints by location.
TALLY_ENDPOINT_TW=
TALLY_ENDPOINT_NL=

# Notion integration (server-side)
# Required to actually persist submissions via the internal API
NOTION_TOKEN=
NOTION_DB_ID=

# When set to "1", /api/submit will also save the submission to Notion (if NOTION_TOKEN/NOTION_DB_ID are set)
SUBMIT_SAVE_TO_NOTION=0

# Registration success emails
# Real sending uses Resend. For local or automated verification, point EMAIL_OUTBOX_FILE to a JSON file.
RESEND_API_KEY=
REGISTRATION_EMAIL_FROM=
REGISTRATION_EMAIL_REPLY_TO=
EMAIL_OUTBOX_FILE=
NEXT_PUBLIC_SITE_URL=

# Plausible Analytics (optional, privacy-friendly)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=

# Cloudflare Turnstile (bot protection)
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITEKEY=
TURNSTILE_SECRET_KEY=

# Sentry error monitoring (optional)
# Get DSN from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
